# Alpha Miner — Environment Configuration
# Copy this file to .env and fill in your values

# ── Claude API ─────────────────────────────────────────
CLAUDE_API_KEY=your_claude_api_key_here
CLAUDE_MODEL=claude-sonnet-4-6
LLM_MAX_CALLS_PER_DAY=20

# ── Database ────────────────────────────────────────────
DATABASE_URL=sqlite:///./alpha_miner.db

# ── WQ Brain ────────────────────────────────────────────
# "manual" = export queue for copy-paste; "auto" = unofficial API
WQ_MODE=manual
WQ_REQUEST_INTERVAL_SEC=3.0
# WQ Brain credentials — do NOT commit to version control
WQ_EMAIL=your@email.com
WQ_PASSWORD=yourpassword
WQ_POLL_INTERVAL_SEC=5.0
WQ_POLL_TIMEOUT_SEC=300.0

# ── Alpha Generation ─────────────────────────────────────
DIVERSITY_THRESHOLD=0.7
PROXY_DATA_TICKERS=500

# ── Genetic Programming ──────────────────────────────────
GP_POPULATION_SIZE=500
GP_GENERATIONS=20
